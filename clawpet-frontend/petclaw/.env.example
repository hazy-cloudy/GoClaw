# PetClaw 前端连接配置示例
# 复制为 .env.local 后按需修改

# 后端 HTTP 地址（默认 18790）
NEXT_PUBLIC_PICOCLAW_API_URL=http://127.0.0.1:18790

# 后端 WebSocket 地址（默认 18790）
NEXT_PUBLIC_PICOCLAW_WS_URL=ws://127.0.0.1:18790

# 直连 gateway 地址（默认 18790）
NEXT_PUBLIC_PICOCLAW_DIRECT_GATEWAY_URL=http://127.0.0.1:18790

# 可选：launcher token（如果你启用了相关鉴权）
NEXT_PUBLIC_PICOCLAW_LAUNCHER_TOKEN=

# 跨域请求是否携带 cookie
NEXT_PUBLIC_PICOCLAW_USE_CREDENTIALS=false

# 仅在 Vercel 部署时开启
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
