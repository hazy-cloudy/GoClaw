{
  "name": "go-claw-electron",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node scripts/wait-and-start.cjs",
    "start:dev": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "start": "electron src/main.js",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
