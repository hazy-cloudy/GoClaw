# PicoClaw 后端连接配置
# 复制此文件为 .env.local 并根据需要修改

# PicoClaw 后端 API 地址（默认：http://127.0.0.1:18800）
NEXT_PUBLIC_PICOCLAW_API_URL=http://127.0.0.1:18800

# PicoClaw WebSocket 地址（默认：ws://127.0.0.1:18800）
NEXT_PUBLIC_PICOCLAW_WS_URL=ws://127.0.0.1:18800

# Launcher 鉴权 token（用于跨端口访问 /api/*，建议本地开发固定设置）
NEXT_PUBLIC_PICOCLAW_LAUNCHER_TOKEN=

# 是否携带 cookie 凭据（跨端口默认 false，避免 CORS 凭据冲突）
NEXT_PUBLIC_PICOCLAW_USE_CREDENTIALS=false

# 仅在部署到 Vercel 并启用 Web Analytics 时设为 true
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
