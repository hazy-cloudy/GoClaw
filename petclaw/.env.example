# PicoClaw frontend connection config
# Copy this file to .env.local and adjust as needed.

# Launcher backend API base (default)
NEXT_PUBLIC_PICOCLAW_API_URL=http://127.0.0.1:18800

# Launcher backend WebSocket base (default)
NEXT_PUBLIC_PICOCLAW_WS_URL=ws://127.0.0.1:18800

# 直连 gateway 地址（默认优先 18790，可改为 false/off 关闭直连回退到 18800）
NEXT_PUBLIC_PICOCLAW_DIRECT_GATEWAY_URL=http://127.0.0.1:18790

# Launcher token used for /api/* calls when auth is enabled
NEXT_PUBLIC_PICOCLAW_LAUNCHER_TOKEN=

# Whether to send cookies on cross-origin requests
NEXT_PUBLIC_PICOCLAW_USE_CREDENTIALS=false

# Enable Vercel Analytics only when deploying on Vercel
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
